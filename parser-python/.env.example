# AI 서비스 제공자 (openai, gemini, claude 중 택 1)
AI_PROVIDER=openai

# OpenAI 사용 시 필수
OPENAI_API_KEY=your_openai_api_key_here

# Gemini 사용 시 필수 (추후 연동용)
GEMINI_API_KEY=your_gemini_api_key_here

# Claude 사용 시 필수 (추후 연동용)
CLAUDE_API_KEY=your_claude_api_key_here

# 내부 데이터베이스 연동 정보 (Spring Boot와 동일한 DB, MySQL/MariaDB용)
DATABASE_URL=mysql+pymysql://root:password@localhost:33306/luxury_jung?charset=utf8mb4
